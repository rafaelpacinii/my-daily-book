{
  "expo": {
    "name": "My Daily Book",
    "slug": "my-daily-book",
    "version": "1.0.0",
    "orientation": "portrait",
    "backgroundColor": "#F5F0E6",
    "primaryColor": "#244A3A",
    "icon": "./assets/images/icon.png",
    "scheme": "mydailybook",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.rafaelpacini.mydailybook",
      "buildNumber": "1"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#244A3A",
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "monochromeImage": "./assets/images/adaptive-icon-monochrome.png"
      },
      "package": "com.rafaelpacini.mydailybook",
      "versionCode": 1,
      "blockedPermissions": [
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE"
      ],
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png",
      "themeColor": "#244A3A"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 240,
          "resizeMode": "contain",
          "backgroundColor": "#F5F0E6",
          "dark": {
            "backgroundColor": "#17231D"
          }
        }
      ],
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "androidStatusBar": {
      "backgroundColor": "#F5F0E6",
      "barStyle": "dark-content"
    },
    "androidNavigationBar": {
      "backgroundColor": "#F5F0E6",
      "barStyle": "dark-content"
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "1f8bb705-0777-4975-b910-2b00113924f3"
      }
    },
    "owner": "rafaelpacinii"
  }
}
